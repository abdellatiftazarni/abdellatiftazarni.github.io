---

import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const certsPost = await getEntry("spec", "certifications");

if (!certsPost) {
	throw new Error("Certifications page content not found");
}

const { Content } = await render(certsPost);
---
<MainGridLayout title="Certifications" description="My cybersecurity certifications">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>
